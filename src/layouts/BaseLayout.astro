---
interface Props {
  title: string;
  description?: string;
  section?: 'noticias' | 'newsletter';
}

const {
  title,
  description = 'Noticias del ecosistema Claude — lanzamientos, actualizaciones y anuncios de Anthropic, filtrados y explicados.',
  section,
} = Astro.props;

const NAV = [
  { href: '/', label: 'Noticias', key: 'noticias' },
  { href: 'https://tuto.automalia.ai', label: 'Guías', key: 'tuto', ext: true },
  { href: 'https://course.automalia.ai', label: 'Cursos', key: 'course', ext: true },
  { href: '/newsletter/', label: 'Newsletter', key: 'newsletter' },
];
const SITE_LABEL = 'Noticias';
const RSS = true;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {RSS && <link rel="alternate" type="application/rss+xml" title="The Claude Hub — Noticias" href="/rss.xml" />}
    <title>{title} · The Claude Hub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap" />
    <style is:global>
      /* ═══ The Claude Hub — Design System "Cosmos" (shared) ═══ */
      :root {
        --void:#020207; --void-2:#060812; --surface-1:#0A0E1C; --surface-2:#10162B; --surface-3:#161E3A;
        --border:rgba(148,163,184,0.08); --border-2:rgba(148,163,184,0.14); --border-glow:rgba(129,140,248,0.40);
        --indigo:#818CF8; --violet:#A78BFA; --magenta:#E879F9; --cyan:#22D3EE; --sky:#38BDF8;
        --primary:#818CF8; --accent:#22D3EE;
        --gradient:linear-gradient(120deg,#818CF8,#22D3EE);
        --gradient-rich:linear-gradient(120deg,#A78BFA 0%,#818CF8 35%,#22D3EE 100%);
        --gradient-aurora:linear-gradient(120deg,#E879F9,#A78BFA,#818CF8,#38BDF8,#22D3EE);
        --glow-i:rgba(129,140,248,0.22); --glow-c:rgba(34,211,238,0.16);
        --text:#F2F5FB; --text-2:#9AA6BE; --text-3:#5A6783;
        --glass:rgba(16,22,43,0.55); --glass-brd:rgba(148,163,184,0.12);
        --font-display:'Space Grotesk',sans-serif; --font-serif:'Instrument Serif',Georgia,serif;
        --font-sans:'Inter',sans-serif; --font-mono:'JetBrains Mono',monospace;
        --r-s:6px; --r-m:12px; --r-l:18px;
        --ease:cubic-bezier(0.22,1,0.36,1);
        --bg:var(--void); --bg-soft:var(--surface-1); --bg-muted:var(--surface-2);
        --ink:var(--text); --ink-2:var(--text); --ink-3:var(--text-2); --muted:var(--text-2); --muted-2:var(--text-3);
        --line:var(--border); --line-soft:var(--border); --accent-ink:var(--cyan); --accent-soft:rgba(34,211,238,0.12);
        --ok:#4ADE80; --ok-soft:rgba(74,222,128,0.12); --warn:#FBBF24; --warn-soft:rgba(251,191,36,0.12);
        --danger:#F87171; --danger-soft:rgba(248,113,113,0.12);
        --shadow-card:0 1px 2px rgba(0,0,0,.3); --shadow-float:0 24px 60px -20px rgba(0,0,0,.6);
      }
      * { box-sizing:border-box; }
      html,body { margin:0; padding:0; }
      html { scroll-behavior:smooth; scrollbar-width:thin; scrollbar-color:var(--surface-3) transparent; }
      ::-webkit-scrollbar { width:8px; } ::-webkit-scrollbar-track { background:var(--void); }
      ::-webkit-scrollbar-thumb { background:var(--surface-3); border-radius:4px; }
      ::selection { background:rgba(129,140,248,0.32); color:#fff; }
      body {
        background:var(--void); color:var(--text); font-family:var(--font-sans);
        font-size:16px; line-height:1.65; -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
        position:relative; overflow-x:hidden;
      }
      body::before {
        content:""; position:fixed; top:-30vh; left:50%; transform:translateX(-50%);
        width:120vw; height:80vh; pointer-events:none; z-index:0;
        background:radial-gradient(ellipse 50% 50% at 30% 40%, rgba(129,140,248,0.10), transparent 70%),
                   radial-gradient(ellipse 45% 45% at 70% 30%, rgba(34,211,238,0.08), transparent 70%);
        filter:blur(40px);
      }
      body::after {
        content:""; position:fixed; inset:0; pointer-events:none; z-index:9999; opacity:0.03;
        background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      }
      a { color:var(--accent); text-decoration:none; }
      a:hover { color:var(--sky); }
      img { max-width:100%; display:block; }
      button { font:inherit; cursor:pointer; background:none; border:none; color:inherit; padding:0; }

      .wrap { max-width:1180px; margin:0 auto; padding:0 28px; position:relative; z-index:1; }
      .wrap-narrow { max-width:780px; margin:0 auto; padding:0 24px; position:relative; z-index:1; }

      .nav { position:sticky; top:0; z-index:50; background:rgba(2,2,7,0.72); backdrop-filter:blur(18px) saturate(1.4); -webkit-backdrop-filter:blur(18px) saturate(1.4); border-bottom:1px solid var(--border); }
      .nav__inner { max-width:1180px; margin:0 auto; padding:14px 28px; display:flex; align-items:center; justify-content:space-between; gap:28px; }
      .logo { display:inline-flex; align-items:center; gap:10px; font-family:var(--font-display); font-weight:600; font-size:18px; letter-spacing:-0.02em; color:var(--text); }
      .logo__mark { width:13px; height:13px; border-radius:50%; background:var(--gradient-rich); box-shadow:0 0 14px var(--glow-i),0 0 24px var(--glow-c); flex-shrink:0; animation:orb 4s ease-in-out infinite; }
      @keyframes orb { 0%,100%{transform:translateY(0) scale(1);} 50%{transform:translateY(-2px) scale(1.1);} }
      .logo__dot { font-family:var(--font-mono); font-size:11px; color:var(--text-3); font-weight:400; letter-spacing:0.05em; }
      .nav__links { display:flex; gap:4px; font-size:14px; }
      .nav__links a { color:var(--text-2); padding:7px 13px; border-radius:8px; transition:color 0.18s, background 0.18s; }
      .nav__links a:hover { color:var(--text); background:rgba(255,255,255,0.04); }
      .nav__links a.is-active { color:var(--text); background:rgba(129,140,248,0.10); }
      .nav__cta { display:flex; gap:10px; align-items:center; }

      .page-content { max-width:1180px; margin:0 auto; padding:48px 28px 96px; position:relative; z-index:1; }

      .eyebrow { font-family:var(--font-mono); font-size:11px; font-weight:500; letter-spacing:0.16em; text-transform:uppercase; color:var(--text-2); }

      .hero {
        border:1px solid var(--border); border-radius:var(--r-l);
        padding:clamp(36px,5vw,72px); position:relative; overflow:hidden; margin-bottom:40px;
        background:linear-gradient(180deg,var(--surface-1),var(--void-2));
      }
      .hero::before { content:""; position:absolute; inset:0; pointer-events:none;
        background:radial-gradient(ellipse 60% 80% at 15% 0%, rgba(129,140,248,0.14), transparent 60%),
                   radial-gradient(ellipse 50% 70% at 90% 20%, rgba(34,211,238,0.10), transparent 60%); }
      .hero::after { content:""; position:absolute; inset:0; pointer-events:none; opacity:0.5;
        background-image:linear-gradient(rgba(148,163,184,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(148,163,184,0.04) 1px,transparent 1px);
        background-size:48px 48px;
        mask-image:radial-gradient(ellipse 70% 60% at 50% 40%,#000 20%,transparent 75%);
        -webkit-mask-image:radial-gradient(ellipse 70% 60% at 50% 40%,#000 20%,transparent 75%); }
      .hero > * { position:relative; z-index:1; }
      .hero-label { font-family:var(--font-mono); font-size:11px; font-weight:500; letter-spacing:0.16em; text-transform:uppercase; color:var(--accent); margin-bottom:22px; display:inline-flex; align-items:center; gap:8px; }
      .hero-label::before { content:""; width:6px; height:6px; border-radius:50%; background:var(--accent); box-shadow:0 0 12px var(--accent); animation:pulse 2s ease-in-out infinite; }
      @keyframes pulse { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:0.4;transform:scale(0.7);} }
      .hero h1 { font-family:var(--font-display); font-weight:700; font-size:clamp(2.4rem,6vw,4.4rem); line-height:1.04; margin:0 0 20px; letter-spacing:-0.035em; color:var(--text); }
      .hero h1 em { font-family:var(--font-serif); font-style:italic; font-weight:400; background:var(--gradient-aurora); background-size:250% auto; -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; animation:hue 8s linear infinite; }
      @keyframes hue { to { background-position:250% center; } }
      .lead { font-size:18px; color:var(--text-2); max-width:680px; line-height:1.6; margin:0 0 28px; }
      .hero-actions { display:flex; gap:12px; flex-wrap:wrap; }

      .section-header { margin:64px 0 24px; padding-bottom:16px; border-bottom:1px solid var(--border); display:flex; justify-content:space-between; align-items:baseline; gap:16px; flex-wrap:wrap; }
      .section-label { font-family:var(--font-mono); font-size:11px; font-weight:500; letter-spacing:0.16em; text-transform:uppercase; color:var(--accent); display:block; margin-bottom:10px; }
      .section-header h2 { font-family:var(--font-display); font-weight:700; font-size:clamp(1.5rem,3vw,2.1rem); letter-spacing:-0.03em; margin:0; color:var(--text); }

      .card-grid { display:grid; gap:18px; grid-template-columns:repeat(auto-fill,minmax(min(100%,300px),1fr)); }
      .card-list { display:grid; gap:14px; }
      .card {
        border:1px solid var(--border); border-radius:var(--r-l); padding:24px;
        background:linear-gradient(180deg,var(--surface-1),var(--void-2));
        transition:border-color 0.3s var(--ease), transform 0.3s var(--ease), box-shadow 0.3s;
        position:relative; overflow:hidden;
      }
      .card:hover { border-color:var(--border-glow); transform:translateY(-4px); box-shadow:0 24px 50px -24px var(--glow-i); }
      .card h2,.card h3 { font-family:var(--font-display); font-weight:600; letter-spacing:-0.02em; margin:0 0 8px; color:var(--text); }
      .card h2 { font-size:1.25rem; } .card h3 { font-size:1.1rem; }
      .card h2 a,.card h3 a { color:var(--text); } .card h2 a:hover,.card h3 a:hover { color:var(--accent); }
      .card p { color:var(--text-2); font-size:0.92rem; line-height:1.6; margin:0; }
      .card ul { color:var(--text-2); font-size:0.92rem; line-height:1.8; margin:0; padding-left:18px; }
      .card ul strong { color:var(--text); }
      .card-meta { display:flex; align-items:center; gap:8px; margin-bottom:12px; flex-wrap:wrap; }

      .tag { display:inline-flex; align-items:center; font-family:var(--font-mono); font-size:10.5px; font-weight:500; letter-spacing:0.06em; text-transform:uppercase; padding:3px 9px; border-radius:999px; border:1px solid var(--border-2); color:var(--text-2); background:rgba(255,255,255,0.02); }
      .date { font-family:var(--font-mono); font-size:10.5px; letter-spacing:0.06em; color:var(--text-3); }
      .pill { display:inline-flex; align-items:center; gap:5px; font-family:var(--font-mono); font-size:10.5px; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; padding:3px 9px; border-radius:999px; }
      .pill::before { content:""; width:5px; height:5px; border-radius:999px; background:currentColor; }
      .pill--ok{color:var(--ok);background:var(--ok-soft);} .pill--warn{color:var(--warn);background:var(--warn-soft);}
      .pill--danger{color:var(--danger);background:var(--danger-soft);} .pill--info{color:var(--accent);background:var(--accent-soft);}

      .button { display:inline-flex; align-items:center; gap:6px; padding:11px 22px; border-radius:999px; font-family:var(--font-display); font-size:14px; font-weight:600; text-decoration:none; transition:transform 0.3s var(--ease), box-shadow 0.3s, background 0.3s; border:1px solid transparent; cursor:pointer; }
      .button-primary { background:var(--gradient); color:#060812; box-shadow:0 8px 30px -10px var(--glow-i); }
      .button-primary:hover { color:#060812; transform:translateY(-3px); box-shadow:0 14px 44px -12px var(--glow-i),0 0 50px -16px var(--glow-c); }
      .button-secondary { background:rgba(255,255,255,0.02); color:var(--text); border-color:var(--border-2); backdrop-filter:blur(8px); }
      .button-secondary:hover { background:rgba(129,140,248,0.08); color:var(--text); border-color:var(--border-glow); transform:translateY(-3px); }

      .chips { display:flex; flex-wrap:wrap; gap:8px; margin:0; padding:0; list-style:none; }
      .chip { border:1px solid var(--border-2); border-radius:999px; color:var(--text-2); padding:5px 13px; font-family:var(--font-mono); font-size:12px; letter-spacing:0.04em; background:rgba(255,255,255,0.02); }

      article.prose { max-width:740px; }
      article.prose h1 { font-family:var(--font-display); font-weight:700; font-size:clamp(1.9rem,4vw,3rem); line-height:1.06; letter-spacing:-0.035em; color:var(--text); margin-bottom:16px; }
      article.prose .prose-meta { display:flex; gap:12px; align-items:center; margin-bottom:32px; padding-bottom:22px; border-bottom:1px solid var(--border); flex-wrap:wrap; }
      article.prose .prose-body { line-height:1.8; color:var(--text-2); font-size:1.02rem; }
      article.prose .prose-body h2 { font-family:var(--font-display); font-weight:600; color:var(--text); letter-spacing:-0.02em; margin-top:2em; }
      article.prose .prose-body h3 { font-family:var(--font-display); font-weight:600; color:var(--text); margin-top:1.5em; }
      article.prose .prose-body a { color:var(--accent); text-decoration:underline; text-underline-offset:3px; }
      article.prose .prose-body code { background:var(--surface-2); border:1px solid var(--border); padding:2px 6px; border-radius:5px; font-family:var(--font-mono); font-size:.875em; color:var(--cyan); }
      article.prose .prose-body pre { background:var(--void-2); border:1px solid var(--border); border-radius:12px; padding:20px; overflow-x:auto; }
      article.prose .prose-body pre code { background:none; border:none; padding:0; color:var(--text-2); }
      article.prose .prose-body blockquote { border-left:3px solid var(--primary); margin:1.5em 0; padding:12px 20px; background:rgba(129,140,248,0.06); border-radius:0 8px 8px 0; color:var(--text-2); font-family:var(--font-serif); font-style:italic; font-size:1.1em; }

      .muted { color:var(--text-2); }
      .rule { height:1px; background:var(--border); border:0; margin:0; }

      .footer { border-top:1px solid var(--border); padding:56px 0 36px; margin-top:96px; color:var(--text-2); font-size:13px; background:var(--void-2); position:relative; z-index:1; }
      .footer__grid { max-width:1180px; margin:0 auto 40px; padding:0 28px; display:grid; grid-template-columns:2fr 1fr 1fr; gap:48px; }
      .footer__col h4 { font-family:var(--font-mono); font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--text-3); margin:0 0 14px; font-weight:500; }
      .footer__col a { display:block; padding:4px 0; color:var(--text-2); transition:color 0.18s; }
      .footer__col a:hover { color:var(--text); }
      .footer__col p { color:var(--text-2); font-size:13px; line-height:1.6; margin:0; max-width:280px; }
      .footer__bar { max-width:1180px; margin:0 auto; padding:20px 28px 0; border-top:1px solid var(--border); display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap; font-family:var(--font-mono); font-size:11.5px; letter-spacing:0.04em; color:var(--text-3); }

      @media (max-width:900px) {
        .nav__links { display:none; }
        .page-content { padding:32px 20px 64px; }
        .footer__grid { grid-template-columns:1fr; gap:28px; padding:0 20px; }
        .footer__bar { padding:16px 20px 0; flex-direction:column; gap:6px; }
        .wrap,.wrap-narrow { padding:0 20px; }
        .card-grid { grid-template-columns:1fr; }
      }
      @media (prefers-reduced-motion: reduce) {
        *{animation:none!important;transition:none!important;} html{scroll-behavior:auto;}
      }
    </style>
  </head>
  <body>
    <nav class="nav">
      <div class="nav__inner">
        <a class="logo" href="https://automalia.ai">
          <span class="logo__mark"></span>
          The Claude Hub
          <span class="logo__dot">·&nbsp;{SITE_LABEL}</span>
        </a>
        <div class="nav__links">
          {NAV.map((n) => (
            <a href={n.href} class={section === n.key ? 'is-active' : ''} {...(n.ext ? { target: '_blank', rel: 'noopener' } : {})}>{n.label}</a>
          ))}
        </div>
        <div class="nav__cta">
          <a class="button button-primary" href="/newsletter/">Suscribirme</a>
        </div>
      </div>
    </nav>

    <div class="page-content">
      <slot />
    </div>

    <footer class="footer">
      <div class="footer__grid">
        <div class="footer__col">
          <div class="logo" style="margin-bottom:12px;font-size:17px;">
            <span class="logo__mark"></span>
            The Claude Hub
          </div>
          <p>El ecosistema Claude en español: noticias, guías y cursos sobre Claude, Claude Code y Anthropic. Un proyecto de automalia.ai.</p>
        </div>
        <div class="footer__col">
          <h4>Servicios</h4>
          <a href="https://automalia.ai">El hub</a>
          <a href="/">Noticias</a>
          <a href="https://tuto.automalia.ai">Guías</a>
          <a href="https://course.automalia.ai">Cursos</a>
        </div>
        <div class="footer__col">
          <h4>Más</h4>
          <a href="/newsletter/">Newsletter</a>
          {RSS && <a href="/rss.xml">RSS</a>}
          <a href="https://automalia.ai">automalia.ai</a>
        </div>
      </div>
      <div class="footer__bar">
        <span>© 2026 The Claude Hub · automalia.ai</span>
        <span>Sin afiliación con Anthropic. Todas las marcas son de sus titulares.</span>
      </div>
    </footer>
  </body>
</html>
