---
interface Props {
  title: string;
  description?: string;
  section?: 'noticias' | 'tutoriales' | 'curso' | 'newsletter';
}

const { title, description = 'The Claude Hub — Novedades, tutoriales y guías sobre Claude, Claude Code y Claude Cowork.', section } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="The Claude Hub" href="/rss.xml" />
    <title>{title} · The Claude Hub</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --accent: #d97706;
        --accent-light: #fbbf24;
        --bg: #0a0a0a;
        --surface: #111111;
        --border: #1f1f1f;
        --text: #e5e5e5;
        --muted: #737373;
        --link: #f59e0b;
      }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--text); }
      a { color: var(--link); }
      a:hover { color: var(--accent-light); }

      header, main, footer { width: min(1020px, calc(100% - 32px)); margin: 0 auto; }

      header {
        padding: 24px 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
      }
      .brand-icon {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #d97706, #f59e0b);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 900;
        color: #000;
        flex-shrink: 0;
      }
      .brand-text { color: #fff; font-weight: 800; letter-spacing: -0.03em; font-size: 1.1rem; }
      .brand-sub { color: var(--muted); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; }

      nav { display: flex; gap: 4px; flex-wrap: wrap; }
      nav a {
        color: var(--muted);
        text-decoration: none;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.15s, background 0.15s;
      }
      nav a:hover { color: var(--text); background: var(--surface); }
      nav a.active { color: var(--accent-light); background: rgba(217,119,6,0.12); }

      main { padding: 36px 0 64px; }
      footer {
        border-top: 1px solid var(--border);
        color: var(--muted);
        padding: 24px 0 40px;
        font-size: 0.85rem;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
      }

      /* Hero */
      .hero {
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: clamp(28px, 5vw, 60px);
        background: radial-gradient(ellipse at top left, rgba(217,119,6,.15), transparent 50%), var(--surface);
        margin-bottom: 32px;
      }
      .hero-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-light);
        margin-bottom: 16px;
        background: rgba(217,119,6,.1);
        padding: 4px 10px;
        border-radius: 99px;
        border: 1px solid rgba(217,119,6,.25);
      }
      .hero h1 {
        font-size: clamp(2rem, 6vw, 4.5rem);
        line-height: .95;
        margin: 0 0 20px;
        letter-spacing: -0.06em;
        color: #fff;
      }
      .hero h1 em { color: var(--accent-light); font-style: normal; }
      .lead { font-size: 1.1rem; color: #a3a3a3; max-width: 680px; line-height: 1.6; margin: 0 0 24px; }
      .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

      /* Cards */
      .section-header { margin: 40px 0 20px; }
      .section-header h2 { font-size: 1.4rem; letter-spacing: -0.03em; margin: 0 0 4px; color: #fff; }
      .section-label { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-light); margin-bottom: 8px; display: block; }

      .card-grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr)); }
      .card-list { display: grid; gap: 14px; }

      .card {
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 20px 22px;
        background: var(--surface);
        transition: border-color 0.15s;
      }
      .card:hover { border-color: #333; }
      .card h2, .card h3 { margin: 0 0 8px; font-size: 1.05rem; letter-spacing: -0.02em; }
      .card h2 a, .card h3 a { color: #fff; text-decoration: none; }
      .card h2 a:hover, .card h3 a:hover { color: var(--accent-light); }
      .card p { color: #a3a3a3; font-size: 0.9rem; line-height: 1.5; margin: 0; }

      .card-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; flex-wrap: wrap; }
      .tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--accent-light);
        background: rgba(217,119,6,.1);
        border: 1px solid rgba(217,119,6,.2);
        padding: 2px 8px;
        border-radius: 99px;
      }
      .date { font-size: 0.8rem; color: var(--muted); }

      /* Buttons */
      .button {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: opacity 0.15s;
      }
      .button:hover { opacity: 0.85; color: inherit; }
      .button-primary { background: var(--accent); color: #000; }
      .button-secondary { background: var(--surface); color: var(--text); border: 1px solid var(--border); }

      /* Chips */
      .chips { display: flex; flex-wrap: wrap; gap: 8px; margin: 0; padding: 0; list-style: none; }
      .chip {
        border: 1px solid var(--border);
        border-radius: 99px;
        color: #a3a3a3;
        padding: 6px 12px;
        font-size: 0.8rem;
        background: rgba(255,255,255,.03);
      }

      /* Article */
      article.prose { max-width: 720px; }
      article.prose h1 { font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1; letter-spacing: -0.05em; color: #fff; margin-bottom: 16px; }
      article.prose .prose-meta { display: flex; gap: 12px; align-items: center; margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid var(--border); flex-wrap: wrap; }
      article.prose .prose-body { line-height: 1.75; color: #d4d4d4; }
      article.prose .prose-body h2 { color: #fff; letter-spacing: -0.03em; margin-top: 2em; }
      article.prose .prose-body h3 { color: #e5e5e5; margin-top: 1.5em; }
      article.prose .prose-body code { background: #1a1a1a; border: 1px solid #2a2a2a; padding: 2px 6px; border-radius: 4px; font-size: 0.875em; color: var(--accent-light); }
      article.prose .prose-body pre { background: #111; border: 1px solid var(--border); border-radius: 10px; padding: 20px; overflow-x: auto; }
      article.prose .prose-body pre code { background: none; border: none; padding: 0; color: #e5e5e5; }
      article.prose .prose-body blockquote { border-left: 3px solid var(--accent); margin: 0; padding: 12px 20px; background: rgba(217,119,6,.05); border-radius: 0 8px 8px 0; color: #a3a3a3; }
      article.prose .prose-body a { color: var(--link); }

      /* Muted util */
      .muted { color: var(--muted); }
    </style>
  </head>
  <body>
    <header>
      <a class="brand" href="/">
        <div class="brand-icon">C</div>
        <div>
          <div class="brand-text">The Claude Hub</div>
          <div class="brand-sub">by automalia.ai</div>
        </div>
      </a>
      <nav aria-label="Principal">
        <a href="/noticias/" class={section === 'noticias' ? 'active' : ''}>Noticias</a>
        <a href="/tutoriales/" class={section === 'tutoriales' ? 'active' : ''}>Tutoriales</a>
        <a href="/curso/" class={section === 'curso' ? 'active' : ''}>Curso</a>
        <a href="/newsletter/" class={section === 'newsletter' ? 'active' : ''}>Newsletter</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <span>The Claude Hub · automalia.ai · Contenido sobre Claude, Claude Code y Claude Cowork</span>
      <span>
        <a href="/rss.xml">RSS</a> ·
        <a href="/newsletter/">Newsletter</a>
      </span>
    </footer>
  </body>
</html>
