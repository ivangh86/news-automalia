---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('tutoriales', e => !e.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const byNivel = {
  basico: all.filter(p => p.data.nivel === 'basico'),
  intermedio: all.filter(p => p.data.nivel === 'intermedio'),
  avanzado: all.filter(p => p.data.nivel === 'avanzado'),
};
---
<BaseLayout title="Tutoriales" description="Guías prácticas sobre Claude, Claude Code y configuraciones paso a paso." section="tutoriales">
  <div class="hero" style="margin-bottom:32px">
    <div class="hero-label">Tutoriales</div>
    <h1 style="font-size:clamp(2rem,5vw,3.5rem);margin:0 0 12px;color:#fff;letter-spacing:-0.05em">Guías <em>paso a paso</em></h1>
    <p class="lead" style="margin:0">Configuraciones, flujos de trabajo y trucos de Claude Code que puedes implementar ahora mismo.</p>
  </div>

  {(['basico','intermedio','avanzado'] as const).map(nivel => byNivel[nivel].length > 0 && (
    <div class="section-header">
      <span class="section-label">{nivel.charAt(0).toUpperCase() + nivel.slice(1)}</span>
    </div>
    <div class="card-grid">
      {byNivel[nivel].map(post => (
        <div class="card">
          <div class="card-meta">
            <span class="tag">{post.data.nivel}</span>
            <span class="date">{post.data.pubDate.toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' })}</span>
          </div>
          <h3><a href={`/tutoriales/${post.id.replace(/\.md$/,'')}/`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <ul class="chips" style="margin-top:12px">
              {post.data.tags.map(t => <li class="chip">{t}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
  ))}

  {all.length === 0 && (
    <div class="card" style="text-align:center;padding:48px">
      <p class="muted">Tutoriales en preparación. Vuelve pronto.</p>
    </div>
  )}
</BaseLayout>
