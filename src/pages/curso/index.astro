---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('curso', e => !e.data.draft))
  .sort((a, b) => a.data.orden - b.data.orden);

const modulos = [...new Set(all.map(p => p.data.modulo))];
---
<BaseLayout title="Curso Claude" description="Aprende Claude y Claude Code desde cero con este curso estructurado por módulos." section="curso">
  <div class="hero" style="margin-bottom:32px">
    <div class="hero-label">Curso</div>
    <h1 style="font-size:clamp(2rem,5vw,3.5rem);margin:0 0 12px;color:#fff;letter-spacing:-0.05em">Claude desde <em>cero</em></h1>
    <p class="lead" style="margin:0">Módulos progresivos para entender y dominar Claude, Claude Code y sus ecosistemas. Sin necesidad de conocimientos previos.</p>
  </div>

  {modulos.map(modulo => (
    <div class="section-header">
      <span class="section-label">Módulo</span>
      <h2>{modulo}</h2>
    </div>
    <div class="card-list">
      {all.filter(p => p.data.modulo === modulo).map(post => (
        <div class="card" style="display:flex;gap:16px;align-items:flex-start">
          <div style="width:32px;height:32px;border-radius:8px;background:rgba(217,119,6,.15);border:1px solid rgba(217,119,6,.3);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:#f59e0b;flex-shrink:0">{post.data.orden}</div>
          <div>
            <h3 style="margin:0 0 6px"><a href={`/curso/${post.id.replace(/\.md$/,'')}/`}>{post.data.title}</a></h3>
            <p style="margin:0">{post.data.description}</p>
          </div>
        </div>
      ))}
    </div>
  ))}

  {all.length === 0 && (
    <div class="card" style="text-align:center;padding:48px">
      <p class="muted">Lecciones en preparación. Vuelve pronto.</p>
    </div>
  )}
</BaseLayout>
