---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('noticias', e => !e.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Noticias" description="Novedades diarias sobre Claude, Claude Code y Anthropic — filtradas y explicadas." section="noticias">
  <div class="hero" style="margin-bottom:32px">
    <div class="hero-label">Noticias</div>
    <h1 style="font-size:clamp(2rem,5vw,3.5rem);margin:0 0 12px;">Novedades sobre <em>Claude</em></h1>
    <p class="lead" style="margin:0">Actualizaciones de Anthropic, lanzamientos y cambios en Claude Code. Sin spam, solo lo que importa.</p>
  </div>
  <div class="card-list">
    {posts.map((post) => (
      <div class="card">
        <div class="card-meta">
          <span class="date">{post.data.pubDate.toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' })}</span>
          {post.data.tags.slice(0,3).map(t => <span class="tag">{t}</span>)}
        </div>
        <h2><a href={`/noticias/${post.id.replace(/\.md$/, '')}/`}>{post.data.title}</a></h2>
        <p>{post.data.description}</p>
      </div>
    ))}
    {posts.length === 0 && (
      <div class="card" style="text-align:center;padding:48px">
        <p class="muted">Primeras noticias en camino.</p>
      </div>
    )}
  </div>
</BaseLayout>
